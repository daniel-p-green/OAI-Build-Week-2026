{
  "name": "workshoplm",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @workshoplm/web dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "demo:reset": "node scripts/reset-demo.mjs",
    "demo:e2e": "tsx scripts/demo-e2e.ts",
    "demo:serve": "WORKSHOPLM_DATA_ROOT=$PWD/.workshoplm/acceptance pnpm --filter @workshoplm/web dev",
    "demo:live": "tsx scripts/live-operator.ts",
    "demo:founder": "tsx scripts/live-operator.ts --root .workshoplm/final-operator --stage-film-inputs",
    "demo:render": "tsx scripts/run-worker-render.ts",
    "demo:thumbnail": "node scripts/render-thumbnail.mjs",
    "demo:capture-draft": "pnpm --filter @workshoplm/web capture:demo",
    "demo:film:rough": "node scripts/build-demo-rough-cut.mjs",
    "demo:film:prepare-live": "tsx scripts/prepare-live-film-evidence.ts",
    "demo:film:narrate": "tsx scripts/generate-demo-film-narration.ts",
    "demo:film:verify": "tsx scripts/verify-demo-film.ts",
    "demo:film:verify-final": "tsx scripts/verify-demo-film.ts --final",
    "dogfood:deck:build": "tsx scripts/rebuild-dogfood-deck.ts",
    "dogfood:review:build": "tsx scripts/build-dogfood-review-packet.ts",
    "dogfood:review:ingest": "tsx scripts/ingest-dogfood-review.ts",
    "dogfood:intents:build": "tsx scripts/render-intent-profile-review.ts",
    "submission:build": "tsx scripts/submission-output-set.ts build",
    "submission:verify": "tsx scripts/submission-output-set.ts verify",
    "plugin:inspect": "pnpm --filter @workshoplm/plugin-mcp test",
    "spike:grounding": "pnpm --filter @workshoplm/spike-grounding run",
    "spike:images": "pnpm --filter @workshoplm/spike-images run",
    "spike:video": "pnpm --filter @workshoplm/spike-video verify",
    "spike:host-sync": "pnpm --filter @workshoplm/spike-host-sync verify",
    "spike:host-sync:verify": "pnpm --filter @workshoplm/spike-host-sync verify"
  },
  "devDependencies": { "@types/node": "^24.0.0", "tsx": "^4.20.0", "turbo": "^2.5.0", "typescript": "^5.8.0", "vitest": "^3.2.0" }
}
