{
  "name": "@workshoplm/web",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run app --passWithNoTests",
    "test:e2e": "tsx scripts/e2e.ts",
    "test:visual": "WORKSHOPLM_NEXT_DIST_DIR=.next-playwright next build && node scripts/normalize-next-env.mjs && playwright test --config playwright.config.ts",
    "capture:demo": "tsx scripts/capture-demo.ts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@workshoplm/ui": "workspace:*",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0"
  }
}
